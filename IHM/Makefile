####### Compile

FenetrePrincipale.o: FenetrePrincipale.cpp FenetrePrincipale.h \
		model/Plan.h \
		model/Mur.h \
		model/Point.h \
		ScenePlan.h \
		GrandeVue.h \
		MiniVue.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o FenetrePrincipale.o FenetrePrincipale.cpp

LoginDialog.o: LoginDialog.cpp LoginDialog.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o LoginDialog.o LoginDialog.cpp

main.o: main.cpp LoginDialog.h \
		FenetrePrincipale.h \
		model/Plan.h \
		model/Mur.h \
		model/Point.h \
		ScenePlan.h \
		GrandeVue.h \
		MiniVue.h \
		model/BDD.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o main.o main.cpp

ScenePlan.o: ScenePlan.cpp ScenePlan.h \
		model/Plan.h \
		model/Mur.h \
		model/Point.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o ScenePlan.o ScenePlan.cpp

moc_FenetrePrincipale.o: moc_FenetrePrincipale.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_FenetrePrincipale.o moc_FenetrePrincipale.cpp

moc_GrandeVue.o: moc_GrandeVue.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_GrandeVue.o moc_GrandeVue.cpp

moc_LoginDialog.o: moc_LoginDialog.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_LoginDialog.o moc_LoginDialog.cpp

moc_MiniVue.o: moc_MiniVue.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_MiniVue.o moc_MiniVue.cpp

moc_ScenePlan.o: moc_ScenePlan.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_ScenePlan.o moc_ScenePlan.cpp

